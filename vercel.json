{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "installCommand": "",
  "functions": {
    "api/*.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/chat.html" },
    { "source": "/europe", "destination": "/europe.html" },
    { "source": "/italy", "destination": "/italy.html" },
    { "source": "/japan", "destination": "/japan.html" },
    { "source": "/australia", "destination": "/australia.html" },
    { "source": "/solo-europe", "destination": "/solo-europe.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
